@inherits LayoutComponentBase
@using LibGit2Sharp
@using System.IO
@using System.Diagnostics
@using System.Text
@using Microsoft.AspNetCore.Hosting
@using Snowflake.Data.Client
@using System.Data
@inject IConfiguration Config
@inject NavigationManager NavManager
@inject IWebHostEnvironment Env

<div class="page">
    <main>
        <div class="top-row px-4" style="background-color: #1b1b1b; color: white; display: flex; justify-content: space-between; align-items: center; border-bottom: 4px solid #89bf04;">
            <h3 style="margin: 0; font-weight: bold;">📊 Reports Automation App</h3>
            
            <div class="d-flex gap-2">
                <button class="btn btn-outline-light" @onclick='() => NavManager.NavigateTo("/snowflake-lab")'>❄ Snowflake Lab</button>
                <button class="btn btn-success" @onclick="SyncAll" disabled="@isSyncing">
                    @if (isSyncing)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span> Syncing Environments...</span>
                    }
                    else
                    {
                        <span>🔄 Sync (Git & Schema)</span>
                    }
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert @(isError ? "alert-danger" : "alert-success") m-3 alert-dismissible fade show" role="alert">
                @statusMessage
                <button type="button" class="btn-close" @onclick="ClearMessage" aria-label="Close"></button>
            </div>
        }

        <article class="content px-4 py-4">
            @Body
        </article>
    </main>
</div>

@code {
    private bool isSyncing = false;
    private string statusMessage = "";
    private bool isError = false;

    private string targetFolderPath = "";

    protected override void OnInitialized()
    {
        // Dynamically point to the wwwroot/FabricRepo folder
        targetFolderPath = Path.Combine(Env.WebRootPath, "FabricRepo");
    }

    private async Task SyncAll()
    {
        isSyncing = true;
        isError = false;
        
        ShowMessage("Starting full environment sync (Git & Snowflake)...", false);
        StateHasChanged();
        
        // Run heavy operations on a background thread
        await Task.Run(() =>
        {
            PerformGitSync();
            
            // Only proceed to Snowflake sync if Git sync didn't fatally crash
            if (!isError)
            {
                PerformSnowflakeSchemaSync();
            }
        });

        if (!isError)
        {
            ShowMessage("✅ All environments (Git & Snowflake Schema) synced successfully!", false);
        }

        isSyncing = false;
        StateHasChanged();
    }

    private void PerformGitSync()
    {
        try
        {
            string repoUrl = Config["GitSettings:RepositoryUrl"];
            string patToken = Config["GitSettings:PersonalAccessToken"];

            if (string.IsNullOrEmpty(repoUrl) || string.IsNullOrEmpty(patToken))
            {
                ShowMessage("❌ Error: RepositoryUrl or PersonalAccessToken is missing from appsettings.json.", true);
                return;
            }

            var credentials = new UsernamePasswordCredentials { Username = "PAT", Password = patToken };

            if (Directory.Exists(targetFolderPath) && !Repository.IsValid(targetFolderPath))
            {
                DeleteDirectory(targetFolderPath);
            }

            if (!Directory.Exists(targetFolderPath))
            {
                Directory.CreateDirectory(targetFolderPath);
            }

            if (Repository.IsValid(targetFolderPath))
            {
                // --- PULL OPERATION (Repo exists) ---
                using (var repo = new Repository(targetFolderPath))
                {
                    // Enforce long paths locally BEFORE pulling
                    repo.Config.Set("core.longpaths", true);

                    var pullOptions = new PullOptions
                    {
                        FetchOptions = new FetchOptions
                        {
                            CredentialsProvider = (url, usernameFromUrl, types) => credentials
                        }
                    };

                    var signature = new Signature("ReportsAutomation", "auto@automation.com", DateTimeOffset.Now);
                    Commands.Pull(repo, signature, pullOptions);
                }
            }
            else
            {
                // --- CLONE OPERATION (Repo does not exist) ---
                var cloneOptions = new CloneOptions
                {
                    FetchOptions = { CredentialsProvider = (url, usernameFromUrl, types) => credentials }
                };

                try
                {
                    // Attempt native LibGit2Sharp Clone first
                    Repository.Clone(repoUrl, targetFolderPath, cloneOptions);
                }
                catch (Exception)
                {
                    // Fallback to native cmd.exe with forced longpaths if LibGit2Sharp crashes
                    DeleteDirectory(targetFolderPath);
                    Directory.CreateDirectory(targetFolderPath);
                    string basicAuthHeader = Convert.ToBase64String(Encoding.ASCII.GetBytes($"PAT:{patToken}"));
                    
                    var processInfo = new ProcessStartInfo
                    {
                        FileName = "cmd.exe",
                        Arguments = $"/c git -c core.longpaths=true -c http.extraheader=\"AUTHORIZATION: basic {basicAuthHeader}\" clone \"{repoUrl}\" \"{targetFolderPath}\"",
                        RedirectStandardError = true,
                        UseShellExecute = false,
                        CreateNoWindow = true
                    };

                    using var process = Process.Start(processInfo);
                    if (process == null)
                    {
                        throw new Exception("Native Git fallback failed to start.");
                    }

                    string errorOutput = process.StandardError.ReadToEnd();
                    process.WaitForExit();

                    if (process.ExitCode != 0)
                    {
                        throw new Exception($"Native Git fallback failed. Details: {errorOutput}");
                    }
                }

                // Regardless of which clone method succeeded, permanently stamp the config into the local repo!
                using (var repo = new Repository(targetFolderPath))
                {
                    repo.Config.Set("core.longpaths", true);
                }
            }
        }
        catch (Exception ex)
        {
            ShowMessage($"❌ Git Error: {ex.Message}", true);
        }
    }
    private void PerformSnowflakeSchemaSync()
    {
        try
        {
            InvokeAsync(() => ShowMessage("Git complete. Fetching Snowflake Schema...", false));

            string connString = Config["Snowflake:ConnectionString"];
            if (string.IsNullOrEmpty(connString))
            {
                // Fallback builder if main ConnectionString is missing
                connString = $"account={Config["Snowflake:Account"]};user={Config["Snowflake:User"]};password={Config["Snowflake:Password"]};db={Config["Snowflake:Database"]};schema={Config["Snowflake:Schema"]};warehouse={Config["Snowflake:Warehouse"]};role={Config["Snowflake:Role"]}";
            }

            using var conn = new SnowflakeDbConnection();
            conn.ConnectionString = connString;
            conn.Open();

            using var cmd = conn.CreateCommand();
            // Fetching ONLY from the VIEWS schema as you specified earlier
            cmd.CommandText = @"
                SELECT TABLE_NAME, COLUMN_NAME, DATA_TYPE 
                FROM INFORMATION_SCHEMA.COLUMNS 
                WHERE TABLE_SCHEMA = 'VIEWS'
                ORDER BY TABLE_NAME, ORDINAL_POSITION;";

            var schemaMap = new StringBuilder();
            schemaMap.AppendLine("### QA_EDW.VIEWS DATABASE SCHEMA ###");
            schemaMap.AppendLine($"Generated on: {DateTime.Now:yyyy-MM-dd HH:mm:ss}");
            schemaMap.AppendLine("---------------------------------------");

            using var reader = cmd.ExecuteReader();
            string currentTable = "";
            
            while (reader.Read())
            {
                string tableName = reader.GetString(0);
                string colName = reader.GetString(1);
                string dataType = reader.GetString(2);

                if (currentTable != tableName)
                {
                    schemaMap.AppendLine();
                    schemaMap.AppendLine($"TABLE: {tableName}");
                    currentTable = tableName;
                }
                schemaMap.AppendLine($"  - {colName} ({dataType})");
            }

            // Save the schema text file into the new SchemaMaps folder inside wwwroot
            string schemaDir = Path.Combine(Env.WebRootPath, "SchemaMaps");
            if (!Directory.Exists(schemaDir))
            {
                Directory.CreateDirectory(schemaDir);
            }
            
            string outFilePath = Path.Combine(schemaDir, "QA_EDW_VIEWS_Schema.txt");
            File.WriteAllText(outFilePath, schemaMap.ToString());
        }
        catch (Exception ex)
        {
            ShowMessage($"❌ Snowflake Schema Sync Error: {ex.Message}", true);
        }
    }
    
    private void ShowMessage(string message, bool error)
    {
        statusMessage = message;
        isError = error;
        InvokeAsync(StateHasChanged);
    }

    private void ClearMessage()
    {
        statusMessage = "";
        StateHasChanged();
    }
    
    private void DeleteDirectory(string path)
    {
        if (string.IsNullOrEmpty(path) || !Directory.Exists(path)) return;
        try
        {
            foreach (var dir in Directory.GetDirectories(path, "*", SearchOption.AllDirectories))
                try { File.SetAttributes(dir, FileAttributes.Normal); } catch { }

            foreach (var file in Directory.GetFiles(path, "*", SearchOption.AllDirectories))
                try { File.SetAttributes(file, FileAttributes.Normal); } catch { }

            Directory.Delete(path, recursive: true);
        }
        catch (Exception ex)
        {
            throw new IOException($"Failed to delete directory: {ex.Message}", ex);
        }
    }
}